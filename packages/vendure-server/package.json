{
  "name": "@simket/vendure-server",
  "version": "0.0.1",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "tsc --build",
    "auth:migrate": "bun x auth migrate",
    "dev": "bun run auth:migrate && tsc --build && concurrently -n server,worker,auth -c blue,green,magenta \"node --env-file=../../.env dist/bootstrap.js\" \"node --env-file=../../.env dist/bootstrap-worker.js\" \"node --env-file=../../.env dist/bootstrap-auth.js\"",
    "dev:server": "tsc --build && node --env-file=../../.env dist/bootstrap.js",
    "dev:worker": "tsc --build && node --env-file=../../.env dist/bootstrap-worker.js",
    "dev:auth": "bun run auth:migrate && tsc --build && node --env-file=../../.env dist/bootstrap-auth.js",
    "dev:watch": "bun run auth:migrate && concurrently \"tsc --build --watch\" \"node --watch --env-file=../../.env dist/bootstrap.js\" \"node --watch --env-file=../../.env dist/bootstrap-worker.js\" \"node --watch --env-file=../../.env dist/bootstrap-auth.js\"",
    "start": "node dist/bootstrap.js",
    "start:auth": "node dist/bootstrap-auth.js",
    "start:worker": "node dist/bootstrap-worker.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist *.tsbuildinfo",
    "migration:generate": "ts-node --esm -e \"console.log('TypeORM migration generate')\"",
    "migration:run": "ts-node --esm -e \"console.log('TypeORM migration run')\""
  },
  "dependencies": {
    "@cedar-policy/cedar-wasm": "^4.9.1",
    "@crowdsec/nodejs-bouncer": "^0.2.0",
    "@juspay-tech/hyperswitch-node": "^2.0.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/graphql": "~13.1.0",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/terminus": "^11.1.1",
    "@openfeature/core": "^1.9.2",
    "@openfeature/server-sdk": "^1.20.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/instrumentation-express": "^0.63.0",
    "@opentelemetry/instrumentation-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@scalar/express-api-reference": "^0.9.8",
    "@simket/editorial": "workspace:*",
    "@simket/shared": "workspace:*",
    "@vendure/asset-server-plugin": "^3.6.2",
    "@vendure/common": "^3.6.2",
    "@vendure/core": "^3.6.2",
    "@vendure/email-plugin": "^3.6.2",
    "@vendure/job-queue-plugin": "^3.6.2",
    "better-auth": "^1.6.5",
    "bullmq": "^5.74.1",
    "clamscan": "^2.4.0",
    "cockatiel": "^3.2.1",
    "exiftool-vendored": "^35.18.0",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "ioredis": "^5.10.1",
    "isomorphic-dompurify": "2.29.0",
    "jose": "^6.2.2",
    "kysely": "^0.28.16",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "stripe": "^22.0.2",
    "svix": "^1.90.0",
    "typeorm": "^0.3.28",
    "typesense": "^3.0.5"
  },
  "devDependencies": {
    "@swc/core": "^1.15.26",
    "@types/clamscan": "^2.4.1",
    "@types/express": "^5.0.6",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.0.0",
    "@vendure/testing": "^3.6.2",
    "better-sqlite3": "^12.9.0",
    "concurrently": "^9.2.1",
    "rimraf": "^6.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^2.1.0"
  }
}
