{
  "name": "simket",
  "private": true,
  "version": "0.0.1",
  "description": "Simket — Digital-goods marketplace",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel --filter=@simket/vendure-server --filter=@simket/storefront",
    "dev:infra": "docker compose up -d",
    "dev:infra:down": "docker compose down",
    "dev:all": "docker compose up -d && turbo run dev --parallel --filter=@simket/vendure-server --filter=@simket/storefront",
    "dev:server": "turbo run dev --filter=@simket/vendure-server",
    "dev:storefront": "turbo run dev --filter=@simket/storefront",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "pipeline": "npx tsx scripts/ci.ts",
    "pipeline:fix": "npx tsx scripts/ci.ts --fix",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "tsx": "^4.21.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
