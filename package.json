{
  "name": "simket",
  "private": true,
  "version": "0.0.1",
  "description": "Simket — Digital-goods marketplace",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "bun@1.3.9",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel --filter=@simket/vendure-server --filter=@simket/storefront",
    "dev:infra": "docker compose up -d",
    "dev:infra:down": "docker compose down",
    "dev:all": "docker compose up -d && turbo run dev --parallel --filter=@simket/vendure-server --filter=@simket/storefront",
    "dev:server": "turbo run dev --filter=@simket/vendure-server",
    "dev:storefront": "turbo run dev --filter=@simket/storefront",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "pipeline": "bun run scripts/ci.ts",
    "pipeline:fix": "bun run scripts/ci.ts --fix",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.26",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.4.0",
    "tsx": "^4.21.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0"
  }
}
