# ═══════════════════════════════════════════════
# Simket Local Development Environment
# Copy to .env and adjust as needed.
# ═══════════════════════════════════════════════

NODE_ENV=development

# ─── Vendure Server ───
VENDURE_PORT=3100
SUPERADMIN_IDENTIFIER=superadmin
SUPERADMIN_PASSWORD=superadmin

# ─── PostgreSQL (direct — dev bypasses PgBouncer) ───
DB_HOST=localhost
DB_PORT=5432
DB_NAME=simket
DB_USER=simket
DB_PASSWORD=simket_dev

# ─── Redis Cache (LRU eviction) ───
REDIS_CACHE_HOST=localhost
REDIS_CACHE_PORT=6379

# ─── Redis Queue (persistent, no eviction) ───
REDIS_QUEUE_HOST=localhost
REDIS_QUEUE_PORT=6380

# ─── Typesense (search) ───
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=simket_dev_key

# ─── Qdrant (vector search) ───
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ─── ClamAV (antivirus) ───
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# ─── Better Auth ───
BETTER_AUTH_URL=http://localhost:3200
BETTER_AUTH_SECRET=dev-secret-change-in-production

# ─── Hyperswitch (payments) ───
HYPERSWITCH_API_KEY=dev_key
HYPERSWITCH_BASE_URL=http://localhost:8080

# ─── CDNgine (asset storage) ───
CDNGINE_BASE_URL=http://localhost:4000

# ─── Convex (real-time state) ───
CONVEX_URL=http://localhost:3210
CONVEX_DEPLOY_KEY=

# ─── Feature Flags (OpenFeature) ───
FEATURE_FLAG_PROVIDER=in-memory

# ─── CrowdSec (disabled in dev) ───
CROWDSEC_ENABLED=false
CROWDSEC_LAPI_URL=http://localhost:8081
CROWDSEC_API_KEY=dev_key
